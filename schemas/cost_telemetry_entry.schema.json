{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ai-workflow-playbook.local/schemas/cost_telemetry_entry.schema.json",
  "title": "AI Cost Telemetry Entry",
  "type": "object",
  "required": [
    "timestamp",
    "project",
    "run_id",
    "source",
    "provider",
    "model",
    "agent_role",
    "environment",
    "input_tokens",
    "output_tokens",
    "total_tokens",
    "estimated_cost_usd"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "description": "ISO-8601 timestamp for the completed call or run."
    },
    "project": {
      "type": "string"
    },
    "task": {
      "type": "string",
      "description": "Playbook task ID such as T07, if applicable."
    },
    "workflow": {
      "type": "string",
      "description": "Application workflow or agent workflow name."
    },
    "run_id": {
      "type": "string",
      "description": "Stable ID tying calls to one run/request/task."
    },
    "source": {
      "type": "string",
      "description": "Where the usage data came from: provider_usage_object, gateway, trace span, manual estimate, etc."
    },
    "provider": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "agent_role": {
      "type": "string"
    },
    "user_or_operator": {
      "type": "string"
    },
    "feature": {
      "type": "string"
    },
    "workload_class": {
      "type": "string",
      "description": "Cost architecture workload class, e.g. architecture_review or summarization_packet."
    },
    "routing_maturity_level": {
      "type": "string",
      "description": "Routing maturity level L0-L6 when relevant."
    },
    "environment": {
      "type": "string"
    },
    "input_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "output_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "total_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "cached_input_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "cache_read_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "cache_write_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "cache_hit": {
      "type": "boolean"
    },
    "reasoning_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "estimated_cost_usd": {
      "type": "number",
      "minimum": 0
    },
    "latency_ms": {
      "type": "number",
      "minimum": 0
    },
    "retry_count": {
      "type": "integer",
      "minimum": 0
    },
    "tool_call_count": {
      "type": "integer",
      "minimum": 0
    },
    "router_decision": {
      "type": "string",
      "description": "Model/provider/workload route chosen by a router, if any."
    },
    "escalation_reason": {
      "type": "string",
      "description": "Reason a call escalated model tier, provider, or verifier path."
    },
    "quality_result": {
      "type": "string",
      "description": "pass, fail, n/a, eval score, or short quality outcome."
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
